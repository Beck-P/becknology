{
  "buildCommand": "bash build.sh",
  "outputDirectory": "public",
  "rewrites": [
    { "source": "/", "destination": "/apps/hub/index.html" },
    { "source": "/runouts", "destination": "/runouts/index.html" },
    { "source": "/runouts/(.*)", "destination": "/runouts/$1" },
    { "source": "/cipher-room", "destination": "/apps/cipher-room/index.html" },
    { "source": "/cipher-room/(.*)", "destination": "/apps/cipher-room/$1" },
    { "source": "/aether-seas", "destination": "/apps/aether-seas/index.html" },
    { "source": "/typist", "destination": "/apps/typist/index.html" },
    { "source": "/typist/(.*)", "destination": "/apps/typist/$1" },
    { "source": "/genart", "destination": "/apps/genart/index.html" },
    { "source": "/bridge", "destination": "/apps/bridge/index.html" },
    { "source": "/bridge/(.*)", "destination": "/apps/bridge/$1" },
    { "source": "/chess", "destination": "/apps/chess/index.html" },
    { "source": "/chess/(.*)", "destination": "/apps/chess/$1" },
    { "source": "/asteroids", "destination": "/apps/asteroids/index.html" },
    { "source": "/breakout", "destination": "/apps/breakout/index.html" },
    { "source": "/helicopter", "destination": "/apps/helicopter/index.html" },
    { "source": "/missile-command", "destination": "/apps/missile-command/index.html" },
    { "source": "/space-invaders", "destination": "/apps/space-invaders/index.html" }
  ]
}
